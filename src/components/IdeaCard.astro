---
interface Props {
  title: string;
  scenario: string;
  tags: string[];
  followups: Array<{ who: string; status: string; note?: string }>;
  slug: string;
}

const { title, scenario, tags, followups, slug } = Astro.props;

const statusMap: Record<string, { label: string; class: string; icon: string }> = {
  exploring: { label: '探索中', class: 'text-parchment/40', icon: 'lucide:search' },
  building: { label: '开发中', class: 'text-gold/60', icon: 'lucide:hammer' },
  shipped: { label: '已实现', class: 'text-emerald/60', icon: 'lucide:check-circle' },
};
---
<div class="panel-glass overflow-hidden reveal break-inside-avoid group">
  <!-- 顶部渐变条 -->
  <div class="h-[3px] bg-gradient-to-r from-gold via-coral to-bio-cyan opacity-70 group-hover:opacity-100 transition-opacity"></div>

  <div class="p-5">
    <div class="flex items-start justify-between gap-3">
      <div class="flex items-center gap-2.5">
        <iconify-icon icon="lucide:lightbulb" width="18" height="18" class="text-gold/60" style="filter: drop-shadow(0 0 6px rgba(212,175,55,0.3))"></iconify-icon>
        <h3 class="text-parchment font-heading text-base leading-snug">{title}</h3>
      </div>
    </div>

    <p class="mt-3 text-parchment/50 text-sm leading-relaxed">{scenario}</p>

    <div class="flex flex-wrap gap-1.5 mt-3">
      {tags.map(tag => (
        <span class="tag-pill">{tag}</span>
      ))}
    </div>

    {followups.length > 0 && (
      <div class="border-t border-white/[0.04] pt-3 mt-4 space-y-1.5">
        <span class="text-parchment/25 text-xs font-mono uppercase tracking-wider mb-2 block">跟进记录</span>
        {followups.map(f => {
          const s = statusMap[f.status] ?? statusMap.exploring;
          return (
            <div class="flex items-center gap-2 text-xs">
              <iconify-icon icon={s.icon} width="12" height="12" class={s.class}></iconify-icon>
              <span class="text-parchment/50">{f.who}</span>
              <span class={s.class}>{s.label}</span>
              {f.note && <span class="text-parchment/25">— {f.note}</span>}
            </div>
          );
        })}
      </div>
    )}

    <a href="/about" class="mt-4 inline-flex items-center gap-1.5 text-xs text-bio-cyan/50 hover:text-bio-cyan transition-colors no-underline">
      <iconify-icon icon="lucide:mail" width="12" height="12"></iconify-icon>
      感兴趣？联系我
    </a>
  </div>
</div>
