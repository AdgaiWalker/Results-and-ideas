---
// GreetingCard.astro
---
<div class="panel-glass p-8 flex flex-col items-center justify-center text-center reveal h-full" id="greeting-card">
  <div class="w-24 h-24 rounded-full bg-abyss border-4 border-parchment/10 flex items-center justify-center mb-6 overflow-hidden shadow-lg relative">
    <div class="absolute inset-0 bg-gradient-to-br from-bio-cyan/20 to-gold/20"></div>
    <iconify-icon icon="lucide:anchor" width="36" height="36" class="text-parchment relative z-10"></iconify-icon>
  </div>
  <div class="font-heading text-parchment-dim text-[17px] tracking-wide mb-1.5" id="greeting-text">
    Good Afternoon
  </div>
  <h2 class="font-heading text-parchment text-[20px] font-medium tracking-wide leading-relaxed">
    I'm <span class="text-bio-cyan text-[24px]">Walker</span> , Nice to<br/>meet you!
  </h2>
</div>

<script>
  function updateGreeting() {
    const hour = new Date().getHours();
    const textEl = document.getElementById('greeting-text');

    if (!textEl) return;

    const greetings: { text: string; range: [number, number] }[] = [
      { text: 'Good Morning', range: [5, 12] },
      { text: 'Good Afternoon', range: [12, 18] },
      { text: 'Good Evening', range: [18, 22] },
      { text: 'Good Night', range: [22, 24] },
      { text: 'Good Night', range: [0, 5] },
    ];

    const g = greetings.find(g => hour >= g.range[0] && hour < g.range[1]) ?? greetings[0];
    textEl.textContent = g.text;
  }

  updateGreeting();
  setInterval(updateGreeting, 60000);
</script>
