---
import { getCollection } from 'astro:content';

const [logs, ideas] = await Promise.all([
  getCollection('log', ({ data }) => data.published),
  getCollection('idea', ({ data }) => data.published),
]);

type Activity = {
  title: string;
  href: string;
  date: Date;
  type: 'log' | 'idea';
};

const activities: Activity[] = [
  ...logs.map(e => ({ title: e.data.title, href: `/log/${e.id}`, date: e.data.date, type: 'log' as const })),
  ...ideas.map(e => ({ title: e.data.title, href: '/ideas', date: e.data.date, type: 'idea' as const })),
];

activities.sort((a, b) => b.date.getTime() - a.date.getTime());
const recent = activities.slice(0, 5);
---
<div class="panel-glass">
  <div class="panel-header">
    <iconify-icon icon="lucide:activity" width="14" height="14" class="text-bio-cyan/50"></iconify-icon>
    SONAR
  </div>
  <div class="p-4 space-y-0">
    {recent.map(item => (
      <a
        href={item.href}
        class="flex items-start gap-3 py-2.5 border-b border-white/[0.04] last:border-0 no-underline group"
      >
        <div class={`mt-1.5 w-2 h-2 rounded-full shrink-0 ${item.type === 'idea' ? 'bg-gold/60' : 'bg-bio-cyan/60'}`}></div>
        <div class="min-w-0 flex-1">
          <span class="text-sm text-parchment/60 group-hover:text-parchment transition-colors truncate block">
            {item.title}
          </span>
        </div>
        <span class="text-xs text-parchment/20 font-mono shrink-0 mt-0.5">
          {item.date.toLocaleDateString('zh-CN', { month: 'short', day: 'numeric' })}
        </span>
      </a>
    ))}
  </div>
</div>
