---
interface Props {
  category?: string;
}

const { category } = Astro.props;

const categories = [
  { key: '', label: '全部', icon: 'lucide:boxes' },
  { key: 'skill', label: 'Skills', icon: 'lucide:wand-2' },
  { key: 'tool', label: '工具', icon: 'lucide:wrench' },
  { key: 'info-source', label: '信息源', icon: 'lucide:radio' },
];
---
<div class="flex flex-wrap gap-2 mb-6">
  {categories.map(c => (
    <a
      href={c.key ? `/dock?category=${c.key}` : '/dock'}
      class:list={[
        'inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-sm font-heading tracking-wider no-underline transition-all',
        (c.key || '') === (category || '')
          ? 'bg-gold/20 text-gold border border-gold/30'
          : 'bg-sea-light/20 text-mist-light border border-transparent hover:border-mist/20 hover:text-parchment',
      ]}
    >
      <iconify-icon icon={c.icon} width="14" height="14"></iconify-icon>
      {c.label}
    </a>
  ))}
</div>
