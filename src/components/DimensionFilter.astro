---
import { DOMAIN_LABELS } from '../utils/domains';
import { FORMAT_LABELS } from '../utils/formats';

interface Props {
  activeDomain?: string;
  activeType?: string;
  activeTag?: string;
  availableTags: string[];
  tagCounts: Record<string, number>;
}

const { activeDomain, activeType, activeTag, availableTags, tagCounts } = Astro.props;

const domains: { key: string; label: string; icon: string }[] = [
  { key: '', label: '全部', icon: 'lucide:layers' },
  { key: 'ai-exploration', label: DOMAIN_LABELS['ai-exploration'], icon: 'lucide:compass' },
  { key: 'ai-life', label: DOMAIN_LABELS['ai-life'], icon: 'lucide:waves' },
];

const types: { key: string; label: string }[] = [
  { key: '', label: '全部形态' },
  ...Object.entries(FORMAT_LABELS).map(([key, label]) => ({ key, label })),
];

function buildUrl(params: Record<string, string | undefined>) {
  const sp = new URLSearchParams();
  if (params.domain) sp.set('domain', params.domain);
  if (params.type) sp.set('type', params.type);
  if (params.tag) sp.set('tag', params.tag);
  const qs = sp.toString();
  return qs ? `/log?${qs}` : '/log';
}
---
<div class="space-y-4 mb-8">
  <!-- 海域 -->
  <div>
    <span class="text-parchment/25 text-xs font-mono uppercase tracking-wider mb-2 block">海域</span>
    <div class="flex flex-wrap gap-2">
      {domains.map(d => (
        <a
          href={buildUrl({ domain: d.key || undefined, type: activeType, tag: activeTag })}
          class:list={[
            'inline-flex items-center gap-1.5 no-underline transition-all duration-200',
            'filter-btn',
            (d.key || '') === (activeDomain || '') ? 'active' : '',
          ]}
        >
          <iconify-icon icon={d.icon} width="14" height="14"></iconify-icon>
          {d.label}
        </a>
      ))}
    </div>
  </div>

  <!-- 形态 -->
  <div>
    <span class="text-parchment/25 text-xs font-mono uppercase tracking-wider mb-2 block">形态</span>
    <div class="flex flex-wrap gap-2">
      {types.map(t => (
        <a
          href={buildUrl({ domain: activeDomain, type: t.key || undefined, tag: activeTag })}
          class:list={[
            'no-underline transition-all duration-200',
            'filter-btn',
            (t.key || '') === (activeType || '') ? 'active' : '',
          ]}
        >
          {t.label}
        </a>
      ))}
    </div>
  </div>

  <!-- 主题 -->
  {availableTags.length > 0 && (
    <div>
      <span class="text-parchment/25 text-xs font-mono uppercase tracking-wider mb-2 block">主题</span>
      <div class="flex flex-wrap gap-2">
        <a
          href={buildUrl({ domain: activeDomain, type: activeType })}
          class:list={[
            'no-underline transition-all duration-200',
            'filter-btn',
            !activeTag ? 'active' : '',
          ]}
        >
          全部主题
        </a>
        {availableTags.map(tag => (
          <a
            href={buildUrl({ domain: activeDomain, type: activeType, tag })}
            class:list={[
              'no-underline transition-all duration-200',
              'filter-btn',
              tag === activeTag ? 'active' : '',
            ]}
          >
            #{tag}
            {tagCounts[tag] && <span class="ml-1 opacity-50">{tagCounts[tag]}</span>}
          </a>
        ))}
      </div>
    </div>
  )}
</div>
