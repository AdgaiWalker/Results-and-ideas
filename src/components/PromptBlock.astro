---
interface Props {
  title?: string;
  tags?: string[];
}

const { title, tags = [] } = Astro.props;
---

<div class="prompt-block my-6 rounded-xl border border-gold/20 bg-gold/5 overflow-hidden">
  <!-- 头部 -->
  <div class="flex items-center justify-between px-4 py-2.5 border-b border-gold/10 bg-gold/5">
    <div class="flex items-center gap-2">
      <svg class="w-3.5 h-3.5 text-gold/60" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="16 18 22 12 16 6"></polyline>
        <polyline points="8 6 2 12 8 18"></polyline>
      </svg>
      <span class="text-gold/70 text-xs font-heading tracking-wider uppercase">Prompt</span>
      {title && (
        <span class="text-parchment/50 text-xs">— {title}</span>
      )}
    </div>
    <div class="flex items-center gap-2">
      {tags.length > 0 && (
        <div class="flex gap-1">
          {tags.map(tag => (
            <span class="text-xs px-1.5 py-0.5 rounded bg-sea-light/30 text-mist-light/60">
              {tag}
            </span>
          ))}
        </div>
      )}
      <button
        class="copy-btn text-gold/40 hover:text-gold text-xs font-mono transition-colors cursor-pointer bg-transparent border-none"
        data-prompt-target="prompt-content"
      >
        复制
      </button>
    </div>
  </div>

  <!-- 提示词内容 -->
  <div class="prompt-content px-5 py-4 text-parchment/80 text-sm font-mono leading-relaxed whitespace-pre-wrap break-words">
    <slot />
  </div>
</div>

<script>
  document.querySelectorAll('.copy-btn').forEach(btn => {
    btn.addEventListener('click', async () => {
      const block = btn.closest('.prompt-block');
      const content = block?.querySelector('.prompt-content')?.textContent?.trim();
      if (!content) return;

      try {
        await navigator.clipboard.writeText(content);
        const original = btn.textContent;
        btn.textContent = '已复制 ✓';
        setTimeout(() => { btn.textContent = original; }, 2000);
      } catch {
        btn.textContent = '复制失败';
      }
    });
  });
</script>

<style>
  .prompt-block {
    break-inside: avoid;
  }
</style>
