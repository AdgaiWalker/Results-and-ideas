---
interface Props {
  title: string;
  description: string;
  href: string;
  icon: string;
  accent: 'cyan' | 'gold' | 'coral' | 'emerald';
  count?: number;
  latestTitle?: string;
  latestDate?: Date;
  latestTag?: string;
}

const { title, description, href, icon, accent, count, latestTitle, latestDate, latestTag } = Astro.props;

const colors = {
  cyan: {
    bar: 'bg-bio-cyan/40',
    iconBg: 'bg-bio-cyan/10',
    iconText: 'text-bio-cyan/70',
    countText: 'text-bio-cyan/30',
    glow: 'group-hover:shadow-[0_0_20px_rgba(0,229,255,0.08)]',
  },
  gold: {
    bar: 'bg-gold/40',
    iconBg: 'bg-gold/10',
    iconText: 'text-gold/70',
    countText: 'text-gold/30',
    glow: 'group-hover:shadow-[0_0_20px_rgba(212,175,55,0.08)]',
  },
  coral: {
    bar: 'bg-coral/40',
    iconBg: 'bg-coral/10',
    iconText: 'text-coral/70',
    countText: 'text-coral/30',
    glow: 'group-hover:shadow-[0_0_20px_rgba(255,107,74,0.08)]',
  },
  emerald: {
    bar: 'bg-emerald/40',
    iconBg: 'bg-emerald/10',
    iconText: 'text-emerald/70',
    countText: 'text-emerald/30',
    glow: 'group-hover:shadow-[0_0_20px_rgba(52,211,153,0.08)]',
  },
};

const c = colors[accent];
---

<a
  href={href}
  class:list={[
    'panel-glass overflow-hidden group no-underline block h-full transition-all duration-300',
    c.glow,
  ]}
>
  <div class:list={['h-1 transition-all duration-300 group-hover:h-1.5', c.bar]}></div>

  <div class="p-5 flex flex-col h-full min-h-[160px]">
    <div class="flex items-center justify-between mb-2.5">
      <div class="flex items-center gap-2.5">
        <div class:list={['w-8 h-8 rounded-lg flex items-center justify-center transition-transform duration-300 group-hover:scale-110', c.iconBg]}>
          <iconify-icon icon={icon} width="16" height="16" class:list={[c.iconText]}></iconify-icon>
        </div>
        <span class="font-heading text-parchment/80 text-sm tracking-wide">{title}</span>
      </div>
      {count !== undefined && (
        <span class:list={['text-xs font-mono', c.countText]}>{count}</span>
      )}
    </div>

    <p class="text-parchment/30 text-xs font-body leading-relaxed mb-auto">{description}</p>

    {latestTitle ? (
      <div class="mt-4 border-t border-white/[0.06] pt-3">
        <div class="text-parchment/50 text-xs font-body truncate group-hover:text-bio-cyan transition-colors">
          {latestTitle}
        </div>
        <div class="flex items-center gap-2 mt-1.5">
          {latestTag && (
            <span class="tag-pill text-[10px]">{latestTag}</span>
          )}
          {latestDate && (
            <span class="text-parchment/20 text-[10px] font-mono">
              {latestDate.toLocaleDateString('zh-CN')}
            </span>
          )}
        </div>
      </div>
    ) : (
      <div class="mt-4 border-t border-white/[0.06] pt-3">
        <span class="text-parchment/20 text-xs font-mono">进入查看 →</span>
      </div>
    )}
  </div>
</a>
