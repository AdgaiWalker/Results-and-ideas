---
interface Props {
  activePlatform?: string;
}

const { activePlatform } = Astro.props;

const platforms = [
  { key: '', label: '全部', icon: 'lucide:layers' },
  { key: 'bilibili', label: 'B 站', icon: 'lucide:tv' },
  { key: 'douyin', label: '抖音', icon: 'lucide:music' },
  { key: 'xiaohongshu', label: '小红书', icon: 'lucide:book-heart' },
  { key: 'zhihu', label: '知乎', icon: 'lucide:graduation-cap' },
  { key: 'github', label: 'GitHub', icon: 'lucide:github' },
];
---
<div class="flex flex-wrap gap-2 mb-6">
  {platforms.map(p => (
    <a
      href={p.key ? `/works?platform=${p.key}` : '/works'}
      class:list={[
        'inline-flex items-center gap-1.5 no-underline transition-all duration-200',
        'filter-btn',
        (p.key || '') === (activePlatform || '') ? 'active' : '',
      ]}
    >
      <iconify-icon icon={p.icon} width="14" height="14"></iconify-icon>
      {p.label}
    </a>
  ))}
</div>
