---
interface Props {
  title: string;
  date: Date;
  tags: string[];
  type: 'article' | 'photo' | 'thought' | 'project' | 'dialogue';
  slug: string;
  cover?: string;
  excerpt?: string;
}

const { title, date, tags, type, slug, cover, excerpt } = Astro.props;

const formatDate = (d: Date) =>
  d.toLocaleDateString('zh-CN', { month: 'short', day: 'numeric' });
---

{type === 'thought' && (
  <a
    href={`/log/${slug}`}
    class="block reveal group mb-6 break-inside-avoid transition-all duration-300 hover:translate-x-1 no-underline"
  >
    <div class="flex items-start gap-3">
      <div class="mt-2 w-1.5 h-1.5 rounded-full bg-mist/60 shrink-0 group-hover:bg-gold transition-colors"></div>
      <div>
        <p class="text-parchment/80 text-base italic leading-relaxed group-hover:text-parchment transition-colors">
          {excerpt || title}
        </p>
        <div class="mt-2 flex items-center gap-2">
          <time class="text-mist text-xs font-mono">{formatDate(date)}</time>
          {tags.filter(t => t !== '随想').map(tag => (
            <span class:list={[
              'text-xs',
              tag === '哲学' ? 'text-gold/70' : 'text-mist/60',
            ]}>#{tag}</span>
          ))}
        </div>
      </div>
    </div>
  </a>
)}

{type === 'article' && (
  <a
    href={`/log/${slug}`}
    class="block reveal group mb-6 break-inside-avoid rounded-xl bg-gradient-to-br from-sea-mid/50 to-sea-mid/20 border border-mist/10 p-6 transition-all duration-300 hover:border-gold/20 hover:-translate-y-1 hover:shadow-xl hover:shadow-gold/5 no-underline"
  >
    <div class="flex items-center gap-2 mb-3">
      <time class="text-mist-light text-xs font-mono tracking-wide">{formatDate(date)}</time>
      <div class="flex gap-1.5">
        {tags.slice(0, 3).map(tag => (
          <span class:list={[
            'text-xs px-1.5 py-0.5 rounded',
            tag === '哲学'
              ? 'bg-gold/15 text-gold/80'
              : 'bg-sea-light/20 text-mist-light/70',
          ]}>
            {tag}
          </span>
        ))}
      </div>
    </div>
    <h3 class="text-parchment font-heading text-lg leading-snug group-hover:text-gold transition-colors duration-200 mb-2">
      {title}
    </h3>
    {excerpt && (
      <p class="text-parchment/50 text-sm leading-relaxed line-clamp-3">
        {excerpt}
      </p>
    )}
    <div class="mt-4 text-gold/40 text-xs font-heading tracking-wider group-hover:text-gold/70 transition-colors">
      阅读 →
    </div>
  </a>
)}

{type === 'photo' && (
  <a
    href={`/log/${slug}`}
    class="block reveal group mb-6 break-inside-avoid no-underline"
  >
    {cover ? (
      <div class="relative overflow-hidden rounded-2xl aspect-[4/3] mb-3">
        <img src={cover} alt={title} class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" loading="lazy" />
        <div class="absolute inset-0 bg-gradient-to-t from-sea-deep/80 via-transparent to-transparent"></div>
        <div class="absolute bottom-0 left-0 right-0 p-4">
          <h3 class="text-parchment font-heading text-base group-hover:text-gold transition-colors">
            {title}
          </h3>
          <time class="text-parchment/50 text-xs font-mono">{formatDate(date)}</time>
        </div>
      </div>
    ) : (
      <div class="rounded-2xl bg-sea-mid/30 border border-mist/10 p-6 aspect-[4/3] flex items-center justify-center">
        <div class="text-center">
          <div class="w-16 h-16 mx-auto mb-3 rounded-full border-2 border-mist/20 flex items-center justify-center">
            <span class="text-mist/40 text-2xl">◎</span>
          </div>
          <h3 class="text-parchment font-heading text-base group-hover:text-gold transition-colors">
            {title}
          </h3>
          <time class="text-mist text-xs font-mono">{formatDate(date)}</time>
        </div>
      </div>
    )}
  </a>
)}

{type === 'project' && (
  <a
    href={`/log/${slug}`}
    class="block reveal group mb-6 break-inside-avoid rounded-lg border border-gold/20 bg-gold/5 p-4 transition-all duration-300 hover:bg-gold/10 hover:border-gold/40 no-underline"
  >
    <div class="flex items-center gap-2 mb-2">
      <div class="w-2 h-2 rounded-full bg-gold/60"></div>
      <span class="text-gold/70 text-xs font-heading tracking-wider uppercase">Project</span>
    </div>
    <h3 class="text-parchment font-heading text-base group-hover:text-gold transition-colors">
      {title}
    </h3>
    {excerpt && (
      <p class="mt-1 text-parchment/40 text-sm line-clamp-2">{excerpt}</p>
    )}
    <time class="mt-2 block text-mist text-xs font-mono">{formatDate(date)}</time>
  </a>
)}

{type === 'dialogue' && (
  <a
    href={`/log/${slug}`}
    class="block reveal group mb-6 break-inside-avoid rounded-xl bg-sea-mid/30 border border-mist/10 p-5 transition-all duration-300 hover:border-gold/15 hover:-translate-y-0.5 no-underline"
  >
    <div class="flex items-center gap-2 mb-3">
      <div class="flex gap-1">
        <div class="w-5 h-5 rounded-full bg-gold/20 flex items-center justify-center text-[8px] text-gold font-heading">W</div>
        <div class="w-5 h-5 rounded-full bg-sea-light/40 flex items-center justify-center text-[8px] text-parchment/50 font-heading">AI</div>
      </div>
      <span class="text-mist-light/40 text-xs font-heading tracking-wider">对话</span>
    </div>
    <h3 class="text-parchment font-heading text-base leading-snug group-hover:text-gold transition-colors mb-2">
      {title}
    </h3>
    {excerpt && (
      <p class="text-parchment/40 text-sm line-clamp-2">{excerpt}</p>
    )}
    <time class="mt-3 block text-mist text-xs font-mono">{formatDate(date)}</time>
  </a>
)}
