---
interface Props {
  tags: string[];
  activeTag?: string;
}

const { tags, activeTag } = Astro.props;
---
<div class="mb-16 relative">
  <div class="flex flex-wrap gap-3 items-center justify-center">
    <a
      href="/log"
      class:list={[
        'no-underline font-heading text-sm tracking-wider px-4 py-1.5 rounded-full transition-all duration-300',
        !activeTag
          ? 'bg-bio-cyan/15 text-bio-cyan border border-bio-cyan/25 shadow-[0_0_8px_rgba(0,229,255,0.1)]'
          : 'text-parchment/40 hover:text-parchment/70',
      ]}
    >
      全部海域
    </a>
    <span class="text-white/[0.06] select-none">·</span>
    {tags.map((tag, i) => (
      <>
        <a
          href={`/log?tag=${encodeURIComponent(tag)}`}
          class:list={[
            'no-underline font-heading text-sm tracking-wider px-3 py-1.5 rounded-full transition-all duration-300',
            activeTag === tag
              ? 'bg-bio-cyan/15 text-bio-cyan border border-bio-cyan/25 shadow-[0_0_8px_rgba(0,229,255,0.1)]'
              : 'text-parchment/30 hover:text-bio-cyan hover:bg-bio-cyan/10',
          ]}
        >
          {tag}
        </a>
        {i < tags.length - 1 && <span class="text-white/[0.06] select-none">·</span>}
      </>
    ))}
  </div>
</div>
