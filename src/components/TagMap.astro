---
import TraceCard from './TraceCard.astro';

interface TagInfo {
  name: string;
  count: number;
  entries: Array<{
    title: string;
    date: Date;
    tags: string[];
    type: 'article' | 'photo' | 'thought' | 'project';
    slug: string;
    cover?: string;
    excerpt?: string;
  }>;
}

interface Props {
  tags: TagInfo[];
}

const { tags } = Astro.props;
const maxCount = Math.max(...tags.map(t => t.count));
---
<div class="space-y-16">
  <!-- 兴趣星图 -->
  <div class="flex flex-wrap gap-3 justify-center">
    {tags.map(tag => {
      const ratio = tag.count / maxCount;
      const size = ratio > 0.7 ? 'text-2xl' : ratio > 0.4 ? 'text-xl' : 'text-base';
      return (
        <a
          href={`#tag-${tag.name}`}
          class:list={[
            'no-underline font-heading px-4 py-2 rounded-full transition-all duration-300',
            'bg-white/[0.04] border border-white/[0.06] text-parchment/50',
            'hover:border-bio-cyan/25 hover:text-bio-cyan hover:shadow-[0_0_8px_rgba(0,229,255,0.1)]',
            size,
          ]}
          style={`opacity: ${0.5 + ratio * 0.5}`}
        >
          {tag.name}
          <span class="ml-1 text-xs opacity-50">{tag.count}</span>
        </a>
      );
    })}
  </div>

  <div class="w-24 h-px bg-gradient-to-r from-transparent via-bio-cyan/20 to-transparent mx-auto"></div>

  {tags.map(tag => (
    <section id={`tag-${tag.name}`}>
      <div class="flex items-center gap-3 mb-6">
        <h2 class="font-heading text-xl text-parchment">{tag.name}</h2>
        <span class="text-parchment/25 text-sm">{tag.count} 篇</span>
      </div>
      <div class="grid gap-4 md:grid-cols-2">
        {tag.entries.map(entry => (
          <TraceCard {...entry} />
        ))}
      </div>
    </section>
  ))}
</div>
