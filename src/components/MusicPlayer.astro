<div class="panel-glass px-4 py-3 flex flex-row items-center justify-between gap-3 group cursor-pointer" id="music-player">
  <div class="flex items-center gap-3 w-full">
    <iconify-icon icon="lucide:music-2" width="16" height="16" class="text-bio-cyan"></iconify-icon>
    <div class="flex-1">
      <div class="text-parchment text-[12px] font-heading font-bold tracking-wider group-hover:text-bio-cyan transition-colors" id="music-title">
        Ocean Ambient
      </div>
      <div class="w-full h-1 bg-parchment-dim/20 rounded-full mt-1.5 overflow-hidden relative">
        <div class="h-full bg-bio-cyan/80 w-1/3 rounded-full relative z-10" id="music-progress">
          <div class="absolute right-0 top-1/2 -translate-y-1/2 w-1.5 h-1.5 bg-bio-cyan rounded-full shadow-[0_0_8px_rgba(0,229,255,0.8)]"></div>
        </div>
        <!-- 背景动效波纹 -->
        <div class="absolute inset-0 flex items-center justify-around px-1 opacity-20" id="music-waves">
          <div class="w-0.5 h-1/2 bg-bio-cyan rounded-full"></div>
          <div class="w-0.5 h-3/4 bg-bio-cyan rounded-full"></div>
          <div class="w-0.5 h-1/2 bg-bio-cyan rounded-full"></div>
          <div class="w-0.5 h-2/3 bg-bio-cyan rounded-full"></div>
        </div>
      </div>

    </div>
  </div>
  <button class="w-8 h-8 rounded-full bg-parchment/5 border border-parchment/10 flex items-center justify-center text-parchment-dim hover:text-bio-cyan hover:bg-bio-cyan/10 transition-colors shrink-0" aria-label="Play" id="music-toggle">
    <iconify-icon icon="lucide:play" width="14" height="14" class="ml-0.5" id="music-icon"></iconify-icon>
  </button>
  
  <!-- 真实的 HTML5 音频元素 -->
  <audio id="ambient-audio" loop src="https://cdn.freesound.org/previews/387/387435_3612089-lq.mp3"></audio>
</div>

<script>
  const toggle = document.getElementById('music-toggle');
  const icon = document.getElementById('music-icon');
  const audio = document.getElementById('ambient-audio') as HTMLAudioElement;
  const waves = document.getElementById('music-waves');
  let playing = false;

  toggle?.addEventListener('click', (e) => {
    e.stopPropagation(); // 防止触发卡片的 3D 效果
    if (!icon || !audio) return;
    
    if (playing) {
      audio.pause();
      icon.setAttribute('icon', 'lucide:play');
      waves?.classList.remove('animate-pulse');
    } else {
      audio.volume = 0.5;
      audio.play().catch(e => console.error("Audio play failed:", e));
      icon.setAttribute('icon', 'lucide:pause');
      waves?.classList.add('animate-pulse');
    }
    playing = !playing;
  });
</script>

<style>
  @keyframes wave-grow {
    0%, 100% { transform: scaleY(1); }
    50% { transform: scaleY(1.5); }
  }
  
  #music-waves div {
    animation: wave-grow 1s ease-in-out infinite;
    animation-play-state: paused;
  }
  
  .animate-pulse #music-waves div {
    animation-play-state: running;
  }
  
  #music-waves div:nth-child(2) { animation-delay: 0.2s; }
  #music-waves div:nth-child(3) { animation-delay: 0.4s; }
  #music-waves div:nth-child(4) { animation-delay: 0.6s; }
</style>

