---
import { getCollection } from 'astro:content';

const allLogs = await getCollection('log', ({ data }) => data.published);
const allIdeas = await getCollection('idea', ({ data }) => data.published);

const allContent = [
  ...allLogs.map(l => {
    const rawText = l.body ? l.body.replace(/<[^>]+>/g, '').replace(/[#*_\`\[\]()>|]/g, '').trim() : '';
    const wordCount = rawText.length;
    const readTime = Math.max(1, Math.ceil(wordCount / 400));
    return {
      title: l.data.title,
      type: l.data.type,
      slug: `/log/${l.id}`,
      tags: l.data.tags,
      excerpt: rawText.slice(0, 80),
      wordCount,
      readTime
    };
  }),
  ...allIdeas.map(i => {
    const rawText = i.data.scenario || '';
    const wordCount = rawText.length;
    const readTime = Math.max(1, Math.ceil(wordCount / 400));
    return {
      title: i.data.title,
      type: 'idea' as const,
      slug: `/ideas`,
      tags: i.data.tags,
      excerpt: rawText.slice(0, 80),
      wordCount,
      readTime
    };
  }),
];

const random = allContent[Math.floor(Math.random() * allContent.length)];

const typeLabels: Record<string, string> = {
  article: '文',
  thought: '想',
  photo: '影',
  project: '项',
  dialogue: '话',
  idea: '灯',
};

const typeColors: Record<string, string> = {
  article: 'bg-bio-cyan/15 text-bio-cyan',
  thought: 'bg-gold/15 text-gold',
  photo: 'bg-emerald/15 text-emerald',
  project: 'bg-gold/15 text-gold',
  dialogue: 'bg-bio-cyan/15 text-bio-cyan',
  idea: 'bg-coral/15 text-coral',
};
---

<div class="panel-glass p-5 flex flex-col h-full group">
  <div class="text-[11px] font-mono text-parchment-dim uppercase tracking-widest mb-3">
    随机推荐
  </div>

  {random ? (
    <a href={random.slug} class="flex items-start gap-3 no-underline">
      <!-- 左侧图标/图片框 -->
      <div class="w-12 h-12 rounded-xl shrink-0 overflow-hidden bg-parchment/5 border border-parchment/10 flex flex-col items-center justify-center relative shadow-sm">
        <iconify-icon icon="lucide:film" width="18" height="18" class="text-parchment-dim"></iconify-icon>
        <span class="text-[8px] font-mono mt-1 text-parchment-dim">Media</span>
      </div>
      
      <!-- 右侧信息 -->
      <div class="flex flex-col flex-1 min-w-0">
        <div class="text-parchment text-[13px] font-heading font-medium leading-snug truncate group-hover:text-bio-cyan transition-colors">
          {random.title}
        </div>
        <div class="text-parchment-dim text-[10px] font-body mt-1 line-clamp-2">
          {random.excerpt || "暂无描述"}
        </div>
        <div class="text-parchment-dim text-[10px] font-mono mt-2 flex items-center gap-2">
          <span>{random.wordCount} 字</span>
          <span class="w-1 h-1 rounded-full bg-parchment-dim/50"></span>
          <span>{random.readTime} 分钟阅读</span>
        </div>
      </div>
    </a>
  ) : (
    <div class="text-parchment-dim text-xs">暂无推荐内容</div>
  )}
</div>
