---
interface Props {
  tags: string[];
  activeTag?: string;
}

const { tags, activeTag } = Astro.props;
---
{tags.length > 0 && (
  <div class="flex flex-wrap gap-2 mb-6">
    <a
      href="/ideas"
      class:list={[
        'px-2.5 py-1 rounded text-xs no-underline transition-all',
        !activeTag ? 'bg-gold/15 text-gold/90' : 'bg-sea-mid/30 text-mist-light/70 hover:text-parchment',
      ]}
    >
      全部
    </a>
    {tags.map(tag => (
      <a
        href={`/ideas?tag=${encodeURIComponent(tag)}`}
        class:list={[
          'px-2.5 py-1 rounded text-xs no-underline transition-all',
          tag === activeTag ? 'bg-gold/15 text-gold/90' : 'bg-sea-mid/30 text-mist-light/70 hover:text-parchment',
        ]}
      >
        #{tag}
      </a>
    ))}
  </div>
)}
