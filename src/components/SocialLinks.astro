---
/**
 * SocialLinks — 社交平台链接组件
 * 在关于页以网格方式展示，在首页以紧凑行展示
 */

interface Props {
  compact?: boolean;
}

const { compact = false } = Astro.props;

const links = [
  { name: 'GitHub', icon: 'lucide:github', href: 'https://github.com/AdgaiWalker', color: 'hover:text-parchment' },
  { name: 'B 站', icon: 'lucide:tv', href: '#', color: 'hover:text-[#00a1d6]' },
  { name: '小红书', icon: 'lucide:book-heart', href: '#', color: 'hover:text-[#ff2442]' },
  { name: '知乎', icon: 'lucide:graduation-cap', href: '#', color: 'hover:text-[#0066ff]' },
];
---

{compact ? (
  <!-- 紧凑模式：一行图标 -->
  <div class="flex items-center gap-3">
    {links.map(link => (
      <a
        href={link.href}
        target="_blank"
        rel="noopener noreferrer"
        class:list={[
          'w-8 h-8 rounded-lg bg-white/[0.04] border border-white/[0.06] flex items-center justify-center',
          'text-parchment/40 transition-all duration-200 no-underline',
          link.color,
          'hover:bg-white/[0.08] hover:border-white/[0.1]',
        ]}
        title={link.name}
        aria-label={link.name}
      >
        <iconify-icon icon={link.icon} width="14" height="14"></iconify-icon>
      </a>
    ))}
  </div>
) : (
  <!-- 完整模式：卡片网格 -->
  <section class="max-w-3xl mx-auto px-6 pb-10">
    <div class="flex items-center gap-4 mb-6">
      <h2 class="text-parchment/25 text-xs font-mono uppercase tracking-wider">社交平台</h2>
      <div class="flex-1 h-px bg-gradient-to-r from-white/[0.08] to-transparent"></div>
    </div>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
      {links.map(link => (
        <a
          href={link.href}
          target="_blank"
          rel="noopener noreferrer"
          class:list={[
            'panel-glass p-4 flex flex-col items-center gap-2 no-underline group transition-all duration-200',
            'hover:border-white/[0.12]',
          ]}
        >
          <div class:list={[
            'w-10 h-10 rounded-xl bg-white/[0.04] border border-white/[0.06] flex items-center justify-center',
            'text-parchment/40 group-hover:scale-110 transition-all duration-200',
            link.color,
          ]}>
            <iconify-icon icon={link.icon} width="18" height="18"></iconify-icon>
          </div>
          <span class="text-parchment/50 text-xs font-heading tracking-wide group-hover:text-parchment transition-colors">
            {link.name}
          </span>
        </a>
      ))}
    </div>
  </section>
)}
