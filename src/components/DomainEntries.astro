---
import { getCollection } from 'astro:content';
import { DOMAIN_LABELS } from '../utils/domains';

const [explorationEntries, lifeEntries] = await Promise.all([
  getCollection('log', ({ data }) => data.published && data.domain === 'ai-exploration')
    .then(e => e.sort((a, b) => b.data.date.getTime() - a.data.date.getTime()).slice(0, 3)),
  getCollection('log', ({ data }) => data.published && data.domain === 'ai-life')
    .then(e => e.sort((a, b) => b.data.date.getTime() - a.data.date.getTime()).slice(0, 3)),
]);

const domains = [
  { key: 'ai-exploration', entries: explorationEntries, icon: 'lucide:compass', color: 'bio-cyan' },
  { key: 'ai-life', entries: lifeEntries, icon: 'lucide:waves', color: 'gold' },
];
---
<div class="space-y-4 md:space-y-5">
  {domains.map(domain => (
    <div class="panel-glass">
      <div class="panel-header">
        <iconify-icon icon={domain.icon} width="14" height="14" class={`text-${domain.color}/50`}></iconify-icon>
        {DOMAIN_LABELS[domain.key]}
      </div>
      <div class="p-4 space-y-2">
        {domain.entries.length > 0 ? (
          <>
            {domain.entries.map(entry => (
              <a
                href={`/log/${entry.id}`}
                class="block group no-underline"
              >
                <div class="flex items-center justify-between py-1.5">
                  <span class="text-sm text-parchment/60 group-hover:text-bio-cyan transition-colors truncate">
                    {entry.data.title}
                  </span>
                  <span class="text-xs text-parchment/20 font-mono shrink-0 ml-3">
                    {entry.data.date.toLocaleDateString('zh-CN', { month: 'short', day: 'numeric' })}
                  </span>
                </div>
              </a>
            ))}
            <a
              href={`/log?domain=${domain.key}`}
              class="block text-xs text-bio-cyan/60 hover:text-bio-cyan transition-colors no-underline pt-2"
            >
              查看全部 →
            </a>
          </>
        ) : (
          <p class="text-parchment/25 text-sm">暂无内容</p>
        )}
      </div>
    </div>
  ))}
</div>
