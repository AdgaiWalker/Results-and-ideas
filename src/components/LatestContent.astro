---
import { getCollection } from 'astro:content';
import TraceCard from './TraceCard.astro';

const allLogs = await getCollection('log', ({ data }) => data.published);
const sorted = allLogs.sort((a, b) => b.data.date.getTime() - a.data.date.getTime()).slice(0, 6);

const entries = sorted.map(entry => {
  const excerpt = (entry.body ?? '')
    .replace(/^---[\s\S]*?---\n*/m, '')
    .replace(/^import.*$/gm, '')
    .replace(/<[^>]+>/g, '')
    .replace(/[#*`\[\]()>|_~-]/g, '')
    .replace(/\n+/g, ' ')
    .trim()
    .slice(0, 120);
  return { ...entry, excerpt };
});
---
<div class="panel-glass">
  <div class="panel-header">
    <iconify-icon icon="lucide:radar" width="14" height="14" class="text-bio-cyan/50"></iconify-icon>
    RECENT TRACES
  </div>
  <div class="p-4 md:p-6">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4" data-stagger>
      {entries.map(entry => (
        <TraceCard
          title={entry.data.title}
          date={entry.data.date}
          tags={entry.data.tags}
          type={entry.data.type}
          domain={entry.data.domain}
          slug={entry.id}
          excerpt={entry.excerpt}
          cover={entry.data.cover}
        />
      ))}
    </div>
  </div>
</div>
