---
---
<!-- 搜索按钮：放在导航栏里 -->
<button
  id="search-open"
  class="flex items-center gap-2 text-mist-light/50 hover:text-parchment/70 transition-colors text-xs font-heading tracking-wider cursor-pointer bg-transparent border-none"
  aria-label="搜索"
>
  <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
    <circle cx="11" cy="11" r="8"></circle>
    <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
  </svg>
  <span class="hidden md:inline">搜索</span>
  <kbd class="hidden md:inline text-[10px] px-1.5 py-0.5 rounded border border-mist/20 text-mist/40 ml-1">⌘K</kbd>
</button>

<!-- 搜索浮层 -->
<div id="search-modal" class="fixed inset-0 z-[100] hidden">
  <!-- 遮罩 -->
  <div id="search-backdrop" class="absolute inset-0 bg-sea-deep/80 backdrop-blur-sm"></div>

  <!-- 搜索面板 -->
  <div class="relative z-10 max-w-2xl mx-auto mt-[15vh] px-4">
    <div class="rounded-2xl border border-mist/20 bg-sea-mid shadow-2xl shadow-sea-deep/50 overflow-hidden">
      <!-- 输入框 -->
      <div class="flex items-center gap-3 px-5 py-4 border-b border-mist/10">
        <svg class="w-5 h-5 text-gold/50 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="11" cy="11" r="8"></circle>
          <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
        </svg>
        <input
          id="search-input"
          type="text"
          placeholder="在这片海域中搜索..."
          class="flex-1 bg-transparent border-none outline-none text-parchment text-base font-body placeholder:text-mist/40"
          autocomplete="off"
        />
        <button
          id="search-close"
          class="text-mist/40 hover:text-parchment/60 text-xs px-2 py-1 rounded border border-mist/15 cursor-pointer bg-transparent font-mono"
        >
          ESC
        </button>
      </div>

      <!-- 结果区域 -->
      <div id="search-results" class="max-h-[50vh] overflow-y-auto px-2 py-2">
        <div id="search-empty" class="py-12 text-center text-mist/40 text-sm">
          输入关键词，探索这片海域
        </div>
        <div id="search-list"></div>
      </div>
    </div>
  </div>
</div>

<style>
  /* 隐藏 Pagefind 默认 UI */
  .pagefind-ui { display: none !important; }
</style>

<script>
  // 搜索浮层逻辑
  const modal = document.getElementById('search-modal');
  const input = document.getElementById('search-input') as HTMLInputElement;
  const openBtn = document.getElementById('search-open');
  const closeBtn = document.getElementById('search-close');
  const backdrop = document.getElementById('search-backdrop');
  const resultsList = document.getElementById('search-list');
  const emptyState = document.getElementById('search-empty');

  function openSearch() {
    modal?.classList.remove('hidden');
    input?.focus();
    document.body.style.overflow = 'hidden';
  }

  function closeSearch() {
    modal?.classList.add('hidden');
    input.value = '';
    if (resultsList) resultsList.innerHTML = '';
    if (emptyState) emptyState.classList.remove('hidden');
    document.body.style.overflow = '';
  }

  openBtn?.addEventListener('click', openSearch);
  closeBtn?.addEventListener('click', closeSearch);
  backdrop?.addEventListener('click', closeSearch);

  document.addEventListener('keydown', (e) => {
    if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
      e.preventDefault();
      openSearch();
    }
    if (e.key === 'Escape') closeSearch();
  });

  // Pagefind 搜索 - 通过 script 标签加载
  let pagefindSearch: any = null;
  let pagefindLoaded = false;
  let pagefindReady: (() => void) | null = null;
  const pagefindReadyPromise = new Promise<void>((resolve) => { pagefindReady = resolve; });

  async function loadPagefind() {
    if (pagefindLoaded) return;
    pagefindLoaded = true;
    const script = document.createElement('script');
    script.src = '/pagefind/pagefind.js';
    script.onload = async () => {
      // @ts-ignore
      pagefindSearch = window.pagefind;
      if (pagefindSearch) {
        await pagefindSearch.init();
        pagefindReady?.();
      }
    };
    script.onerror = () => {
      console.log('Pagefind not available - run build first');
    };
    document.head.appendChild(script);
  }

  // 首次打开搜索时加载
  const origOpen = openSearch;
  openSearch = function() {
    origOpen();
    loadPagefind();
  };

  let debounceTimer: ReturnType<typeof setTimeout>;
  input?.addEventListener('input', () => {
    clearTimeout(debounceTimer);
    debounceTimer = setTimeout(async () => {
      await pagefindReadyPromise;
      const query = input.value.trim();
      if (!query || !pagefindSearch) {
        if (resultsList) resultsList.innerHTML = '';
        if (emptyState) {
          emptyState.classList.remove('hidden');
          emptyState.textContent = !pagefindSearch
            ? '搜索索引加载中...'
            : '输入关键词，探索这片海域';
        }
        return;
      }

      const results = await pagefindSearch.search(query);
      if (results.results.length === 0) {
        if (resultsList) resultsList.innerHTML = '';
        if (emptyState) {
          emptyState.classList.remove('hidden');
          emptyState.textContent = `没有找到「${query}」相关的记录`;
        }
        return;
      }

      if (emptyState) emptyState.classList.add('hidden');

      const html = await Promise.all(
        results.results.slice(0, 8).map(async (r: any) => {
          const data = await r.data();
          return `
            <a href="${data.url}" class="block px-4 py-3 rounded-lg hover:bg-sea-light/30 transition-colors no-underline group">
              <div class="text-parchment text-sm font-heading group-hover:text-gold transition-colors mb-1">
                ${data.meta?.title || data.url}
              </div>
              <p class="text-parchment/40 text-xs line-clamp-2">${data.excerpt || ''}</p>
            </a>
          `;
        })
      );

      if (resultsList) resultsList.innerHTML = html.join('');
    }, 200);
  });
</script>
