---
import { PLATFORM_LABELS, PLATFORM_ICONS, PLATFORM_COLORS } from '../utils/platforms';

interface Props {
  title: string;
  platform: string;
  url: string;
  cover?: string;
  description: string;
  tags: string[];
}

const { title, platform, url, cover, description, tags } = Astro.props;

const platformLabel = PLATFORM_LABELS[platform] ?? platform;
const platformIcon = PLATFORM_ICONS[platform] ?? 'lucide:link';
const platformColor = PLATFORM_COLORS[platform] ?? '#8b949e';
---
<a
  href={url}
  target="_blank"
  rel="noopener noreferrer"
  class="block reveal no-underline group"
>
  <div class="panel-glass overflow-hidden transition-all duration-300 hover:border-white/[0.15]">
    <!-- 顶部品牌色条 -->
    <div class="h-[1.5px] group-hover:h-[2px] transition-all" style={`background: ${platformColor}; box-shadow: 0 1px 4px ${platformColor}40`}></div>

    <div class="p-5">
      <div class="flex items-center gap-2 mb-3">
        <iconify-icon icon={platformIcon} width="14" height="14" style={`color: ${platformColor}99`}></iconify-icon>
        <span class="text-xs font-mono tracking-wider" style={`color: ${platformColor}80`}>{platformLabel}</span>
      </div>

      <h3 class="text-parchment font-heading text-base mb-2 group-hover:text-bio-cyan transition-colors">{title}</h3>
      <p class="text-parchment/50 text-sm leading-relaxed mb-3">{description}</p>

      <div class="flex flex-wrap gap-1.5">
        {tags.map(tag => (
          <span class="tag-pill">{tag}</span>
        ))}
      </div>

      <div class="mt-4 flex items-center gap-1.5 text-xs text-parchment/30 group-hover:text-bio-cyan/60 transition-colors">
        <iconify-icon icon="lucide:external-link" width="12" height="12"></iconify-icon>
        查看作品
      </div>
    </div>
  </div>
</a>
