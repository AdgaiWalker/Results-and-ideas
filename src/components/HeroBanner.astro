---
import { getCollection } from 'astro:content';

const [logs, ideas, dockItems, works] = await Promise.all([
  getCollection('log', ({ data }) => data.published),
  getCollection('idea', ({ data }) => data.published),
  getCollection('dockItem', ({ data }) => data.published),
  getCollection('work', ({ data }) => data.published),
]);
---
<div class="panel-glass h-full flex flex-col">
  <!-- 标题栏 -->
  <div class="panel-header">
    <iconify-icon icon="lucide:compass" width="14" height="14" class="text-bio-cyan/50"></iconify-icon>
    CAPTAIN'S LOG
  </div>

  <!-- 主体 -->
  <div class="flex-1 flex flex-col justify-center px-6 md:px-8 py-8 md:py-12">
    <h1 class="font-heading text-4xl md:text-5xl lg:text-6xl font-bold text-parchment tracking-wide">
      Walker
    </h1>
    <p class="mt-3 text-base md:text-lg text-parchment/50 font-body">
      行过万里水路，记录每一次停靠
    </p>
  </div>

  <!-- 统计栏 -->
  <div class="flex items-center gap-5 md:gap-6 px-6 md:px-8 py-4 border-t border-white/[0.06]">
    <div class="flex items-center gap-2">
      <iconify-icon icon="lucide:book-open" width="14" height="14" class="text-bio-cyan/50"></iconify-icon>
      <span class="text-sm text-parchment/50">
        <span class="text-bio-cyan font-mono">{logs.length}</span> 日志
      </span>
    </div>
    <div class="flex items-center gap-2">
      <iconify-icon icon="lucide:lightbulb" width="14" height="14" class="text-gold/50"></iconify-icon>
      <span class="text-sm text-parchment/50">
        <span class="text-gold font-mono">{ideas.length}</span> Ideas
      </span>
    </div>
    <div class="flex items-center gap-2">
      <iconify-icon icon="lucide:wrench" width="14" height="14" class="text-coral/50"></iconify-icon>
      <span class="text-sm text-parchment/50">
        <span class="text-coral font-mono">{dockItems.length}</span> 工具
      </span>
    </div>
    <div class="flex items-center gap-2">
      <iconify-icon icon="lucide:tv" width="14" height="14" class="text-emerald/50"></iconify-icon>
      <span class="text-sm text-parchment/50">
        <span class="text-emerald font-mono">{works.length}</span> 作品
      </span>
    </div>
  </div>

  <!-- 快捷导航 -->
  <div class="flex items-center gap-3 px-6 md:px-8 py-4 border-t border-white/[0.06]">
    <a href="/log" class="w-10 h-10 rounded-full bg-white/[0.04] border border-white/[0.08] flex items-center justify-center hover:bg-bio-cyan/10 hover:border-bio-cyan/20 transition-all no-underline" title="日志">
      <iconify-icon icon="lucide:book-open" width="16" height="16" class="text-parchment/50"></iconify-icon>
    </a>
    <a href="/ideas" class="w-10 h-10 rounded-full bg-white/[0.04] border border-white/[0.08] flex items-center justify-center hover:bg-gold/10 hover:border-gold/20 transition-all no-underline" title="Ideas">
      <iconify-icon icon="lucide:lightbulb" width="16" height="16" class="text-parchment/50"></iconify-icon>
    </a>
    <a href="/dock" class="w-10 h-10 rounded-full bg-white/[0.04] border border-white/[0.08] flex items-center justify-center hover:bg-coral/10 hover:border-coral/20 transition-all no-underline" title="补给舱">
      <iconify-icon icon="lucide:wrench" width="16" height="16" class="text-parchment/50"></iconify-icon>
    </a>
    <a href="/compass" class="w-10 h-10 rounded-full bg-white/[0.04] border border-white/[0.08] flex items-center justify-center hover:bg-bio-cyan/10 hover:border-bio-cyan/20 transition-all no-underline" title="指南针">
      <iconify-icon icon="lucide:compass" width="16" height="16" class="text-parchment/50"></iconify-icon>
    </a>
  </div>
</div>
