---
import TraceCard from './TraceCard.astro';
import { getCollection } from 'astro:content';

const allLogs = await getCollection('log', ({ data }) => data.published);
const recentLogs = allLogs
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 6);
---
<section class="max-w-5xl mx-auto px-6 py-20">
  <div class="flex items-center gap-4 mb-10">
    <h2 class="font-heading text-2xl text-parchment tracking-wide">最近痕迹</h2>
    <div class="flex-1 h-px bg-gradient-to-r from-gold/20 to-transparent"></div>
  </div>
  <div class="columns-1 md:columns-2 lg:columns-3 gap-6">
    {recentLogs.map(entry => (
      <TraceCard
        title={entry.data.title}
        date={entry.data.date}
        tags={entry.data.tags}
        type={entry.data.type}
        slug={entry.id}
        cover={entry.data.cover}
        excerpt={entry.body ? entry.body.replace(/^import\s+.*$/gm, '').replace(/<[^>]+>/g, '').replace(/[#*_`\[\]()>|]/g, '').trim().slice(0, 150) + '...' : undefined}
      />
    ))}
  </div>
  <div class="mt-12 text-center">
    <a
      href="/log"
      class="inline-block font-heading text-sm text-gold/60 hover:text-gold transition-colors tracking-wider no-underline"
    >
      进入全部日志 →
    </a>
  </div>
</section>
