---
interface Props {
  role: 'human' | 'ai';
  name?: string;
}

const { role, name } = Astro.props;
const isHuman = role === 'human';
---

<div class:list={[
  'flex gap-3 my-3',
  isHuman ? 'flex-row' : 'flex-row-reverse',
]}>
  <!-- 头像 -->
  <div class:list={[
    'shrink-0 w-8 h-8 rounded-full flex items-center justify-center text-xs font-heading',
    isHuman
      ? 'bg-gold/15 text-gold/70 border border-gold/20'
      : 'bg-bio-cyan/10 text-bio-cyan/60 border border-bio-cyan/15',
  ]}>
    {isHuman ? 'W' : 'AI'}
  </div>

  <!-- 气泡 -->
  <div class:list={[
    'max-w-[80%] rounded-2xl px-4 py-3',
    isHuman
      ? 'bg-gold/[0.06] border border-gold/15 rounded-tl-sm shadow-[inset_0_0_16px_rgba(212,175,55,0.05)]'
      : 'bg-bio-cyan/[0.05] border border-bio-cyan/15 rounded-tr-sm shadow-[inset_0_0_16px_rgba(0,229,255,0.05)]',
  ]}>
    {name && (
      <div class:list={[
        'text-xs font-mono mb-1.5 tracking-wider',
        isHuman ? 'text-gold/50' : 'text-bio-cyan/50',
      ]}>
        {name}
      </div>
    )}
    <div class="text-parchment/75 text-sm leading-relaxed">
      <slot />
    </div>
  </div>
</div>
