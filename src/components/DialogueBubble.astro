---
interface Props {
  role: 'human' | 'ai';
  name?: string;
}

const { role, name } = Astro.props;
const isHuman = role === 'human';
---

<div class:list={[
  'flex gap-3 my-3',
  isHuman ? 'flex-row' : 'flex-row-reverse',
]}>
  <!-- 头像 -->
  <div class:list={[
    'shrink-0 w-8 h-8 rounded-full flex items-center justify-center text-xs font-heading',
    isHuman
      ? 'bg-gold/20 text-gold'
      : 'bg-sea-light/40 text-parchment/60',
  ]}>
    {isHuman ? 'W' : 'AI'}
  </div>

  <!-- 气泡 -->
  <div class:list={[
    'max-w-[80%] rounded-2xl px-4 py-3',
    isHuman
      ? 'bg-gold/10 border border-gold/15 rounded-tl-sm'
      : 'bg-sea-mid/50 border border-mist/10 rounded-tr-sm',
  ]}>
    {name && (
      <div class:list={[
        'text-xs font-heading mb-1.5 tracking-wider',
        isHuman ? 'text-gold/60' : 'text-mist-light/50',
      ]}>
        {name}
      </div>
    )}
    <div class="text-parchment/85 text-sm leading-relaxed">
      <slot />
    </div>
  </div>
</div>
