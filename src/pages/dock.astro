---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';
import DockItemCard from '../components/DockItemCard.astro';

const allItems = await getCollection('dockItem', ({ data }) => data.published);

const categoryLabels: Record<string, string> = {
  skill: '技能',
  tool: '工具',
  'info-source': '信息源',
};
const categories = [...new Set(allItems.map(e => e.data.category))];
---

<Base title="补给舱 — Walker">
  <div class="max-w-5xl mx-auto px-6 pt-28 pb-20">
    <div class="mb-10">
      <div class="flex items-center gap-3 mb-1">
        <span class="w-1.5 h-1.5 rounded-full bg-coral/60"></span>
        <span class="text-xs font-mono text-parchment/25 uppercase tracking-wider">Dock</span>
      </div>
      <h1 class="font-heading text-4xl md:text-5xl text-parchment tracking-wide">补给舱</h1>
      <p class="text-parchment/40 text-sm font-body mt-3">
        Walker 使用的工具、制作的 Skills 和关注的信息源。
      </p>
      <div class="mt-4 h-px bg-gradient-to-r from-white/[0.08] to-transparent"></div>
    </div>

    <!-- 搜索 + 分类筛选 -->
    <div class="mb-8 space-y-3">
      <div class="relative">
        <iconify-icon icon="lucide:search" width="14" height="14" class="absolute left-3 top-1/2 -translate-y-1/2 text-parchment/25"></iconify-icon>
        <input
          id="dock-search"
          type="text"
          placeholder="搜索工具、技能或信息源..."
          class="w-full bg-white/[0.03] border border-white/[0.08] rounded-lg pl-9 pr-4 py-2.5 text-sm text-parchment placeholder:text-parchment/25 outline-none focus:border-bio-cyan/30 focus:shadow-[0_0_12px_rgba(0,229,255,0.1)] transition-all font-body"
        />
      </div>
      <div class="flex flex-wrap gap-2" id="dock-filters">
        <button class="filter-btn active" data-value="">全部</button>
        {categories.map(cat => (
          <button class="filter-btn" data-value={cat}>{categoryLabels[cat] ?? cat}</button>
        ))}
      </div>
    </div>

    {allItems.length === 0 ? (
      <p class="text-parchment/30 text-center py-20">补给舱暂时没有内容。</p>
    ) : (
      <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-3" id="dock-list">
        {allItems.map(item => (
          <div
            class="dock-item"
            data-category={item.data.category}
            data-name={item.data.name.toLowerCase()}
            data-desc={item.data.description.toLowerCase()}
            data-tags={item.data.tags.join(',').toLowerCase()}
          >
            <DockItemCard
              name={item.data.name}
              description={item.data.description}
              category={item.data.category}
              tags={item.data.tags}
              rating={item.data.rating}
              url={item.data.url}
            />
          </div>
        ))}
      </div>
    )}

    <p id="dock-empty" class="text-parchment/30 text-center py-20 hidden">
      没有找到匹配的内容。
    </p>
  </div>

  <script>
    let activeCategory = '';
    let searchQuery = '';
    const items = document.querySelectorAll<HTMLElement>('.dock-item');
    const emptyEl = document.getElementById('dock-empty');
    const listEl = document.getElementById('dock-list');
    const searchInput = document.getElementById('dock-search') as HTMLInputElement;

    function applyFilter() {
      let visible = 0;
      items.forEach(item => {
        const cat = item.dataset.category ?? '';
        const name = item.dataset.name ?? '';
        const desc = item.dataset.desc ?? '';
        const tags = item.dataset.tags ?? '';

        const matchCat = !activeCategory || cat === activeCategory;
        const matchSearch = !searchQuery ||
          name.includes(searchQuery) ||
          desc.includes(searchQuery) ||
          tags.includes(searchQuery);

        if (matchCat && matchSearch) {
          item.style.display = '';
          visible++;
        } else {
          item.style.display = 'none';
        }
      });
      if (emptyEl) emptyEl.classList.toggle('hidden', visible > 0);
      if (listEl) listEl.classList.toggle('hidden', visible === 0);
    }

    document.querySelectorAll<HTMLElement>('#dock-filters .filter-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        activeCategory = btn.dataset.value ?? '';
        document.querySelectorAll('#dock-filters .filter-btn').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        applyFilter();
      });
    });

    searchInput?.addEventListener('input', () => {
      searchQuery = searchInput.value.trim().toLowerCase();
      applyFilter();
    });
  </script>
</Base>
