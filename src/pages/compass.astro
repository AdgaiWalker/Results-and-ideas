---
import Base from '../layouts/Base.astro';
import TagMap from '../components/TagMap.astro';
import { getCollection } from 'astro:content';

const allLogs = await getCollection('log', ({ data }) => data.published);

const tagMap = new Map<string, Array<{
  title: string;
  date: Date;
  tags: string[];
  type: 'article' | 'photo' | 'thought' | 'project' | 'dialogue';
  slug: string;
  cover?: string;
  excerpt?: string;
}>>();

allLogs.forEach(entry => {
  entry.data.tags.forEach(tag => {
    if (!tagMap.has(tag)) tagMap.set(tag, []);
    tagMap.get(tag)!.push({
      title: entry.data.title,
      date: entry.data.date,
      tags: entry.data.tags,
      type: entry.data.type,
      slug: entry.id,
      cover: entry.data.cover,
      excerpt: entry.body ? entry.body.replace(/^import\s+.*$/gm, '').replace(/<[^>]+>/g, '').replace(/[#*_`\[\]()>|]/g, '').trim().slice(0, 120) + '...' : undefined,
    });
  });
});

const tags = [...tagMap.entries()]
  .map(([name, entries]) => ({
    name,
    count: entries.length,
    entries: entries.sort((a, b) => b.date.getTime() - a.date.getTime()),
  }))
  .sort((a, b) => b.count - a.count);

const totalPosts = allLogs.length;
const totalTags = tags.length;

const axioms = [
  { name: '人类主权', icon: 'lucide:crown', content: 'AI 负责逻辑推演、信息整理、方案生成等二次工作；人类负责价值判断、审美判断、最终拍板。' },
  { name: '熵减命令', icon: 'lucide:arrow-down-right', content: '系统的唯一目的是高熵（混乱/未知）转化为低熵（结构/已知）。' },
  { name: '多元世界观', icon: 'lucide:git-branch', content: '蓝图层 = 应然（流动的意识）；现实层 = 实然（流动的物质）；偏差驱动行动。' },
  { name: '量变质变', icon: 'lucide:infinity', content: '记录积累到一定量时，分析研究过程，为人机交互的安全与预警提供判断依据。' },
  { name: '做减法', icon: 'lucide:minus', content: '如无必要，勿增实体。最简路径即最优路径。' },
];
---
<Base title="指南针 — Walker">
  <div class="max-w-4xl mx-auto px-6 pt-28 pb-20">
    <div class="text-center mb-20">
      <div class="flex items-center justify-center gap-2 mb-4">
        <span class="w-1.5 h-1.5 rounded-full bg-bio-cyan/60"></span>
        <span class="text-xs font-mono text-parchment/25 uppercase tracking-wider">Compass</span>
      </div>
      <h1 class="font-heading text-3xl text-parchment mb-4 tracking-wide">指南针</h1>
      <p class="text-parchment/40 text-base">
        核心方法论与兴趣图谱 — {totalPosts} 篇日志，{totalTags} 个方向
      </p>
    </div>

    <!-- 五层逻辑 -->
    <section class="mb-24">
      <div class="flex items-center gap-4 mb-10">
        <h2 class="text-parchment/25 text-xs font-mono uppercase tracking-wider">操作系统</h2>
        <div class="flex-1 h-px bg-gradient-to-r from-white/[0.08] to-transparent"></div>
      </div>

      <div class="space-y-4">
        {axioms.map(axiom => (
          <div class="panel-glass group flex gap-5 items-start p-5">
            <div class="shrink-0 w-12 h-12 bg-white/[0.04] border border-white/[0.08] rounded-xl flex items-center justify-center transition-all duration-300 group-hover:shadow-[0_0_12px_rgba(0,229,255,0.15)]">
              <iconify-icon icon={axiom.icon} width="20" height="20" class="text-parchment/40 group-hover:text-bio-cyan/70 transition-colors"></iconify-icon>
            </div>
            <div>
              <h3 class="font-heading text-parchment text-base mb-1 group-hover:text-bio-cyan transition-colors">
                {axiom.name}
              </h3>
              <p class="text-parchment/45 text-sm leading-relaxed">
                {axiom.content}
              </p>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- 标签图谱 -->
    <section>
      <div class="flex items-center gap-4 mb-10">
        <h2 class="text-parchment/25 text-xs font-mono uppercase tracking-wider">兴趣星图</h2>
        <div class="flex-1 h-px bg-gradient-to-r from-white/[0.08] to-transparent"></div>
      </div>

      <p class="text-parchment/35 text-sm mb-8 text-center max-w-md mx-auto leading-relaxed">
        不定义自己是什么，而是展示自己关注什么。点击任一方向，探索那片海域。
      </p>

      <TagMap tags={tags} />
    </section>
  </div>

</Base>
