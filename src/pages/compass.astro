---
import Base from '../layouts/Base.astro';
import TagMap from '../components/TagMap.astro';
import { getCollection } from 'astro:content';

const allLogs = await getCollection('log', ({ data }) => data.published);

const tagMap = new Map<string, Array<{
  title: string;
  date: Date;
  tags: string[];
  type: 'article' | 'photo' | 'thought' | 'project' | 'dialogue';
  slug: string;
  cover?: string;
  excerpt?: string;
}>>();

allLogs.forEach(entry => {
  entry.data.tags.forEach(tag => {
    if (!tagMap.has(tag)) tagMap.set(tag, []);
    tagMap.get(tag)!.push({
      title: entry.data.title,
      date: entry.data.date,
      tags: entry.data.tags,
      type: entry.data.type,
      slug: entry.id,
      cover: entry.data.cover,
      excerpt: entry.body ? entry.body.replace(/^import\s+.*$/gm, '').replace(/<[^>]+>/g, '').replace(/[#*_`\[\]()>|]/g, '').trim().slice(0, 120) + '...' : undefined,
    });
  });
});

const tags = [...tagMap.entries()]
  .map(([name, entries]) => ({
    name,
    count: entries.length,
    entries: entries.sort((a, b) => b.date.getTime() - a.date.getTime()),
  }))
  .sort((a, b) => b.count - a.count);

const totalPosts = allLogs.length;
const totalTags = tags.length;

const axioms = [
  {
    name: '人类主权',
    symbol: '⊕',
    content: 'AI 负责逻辑推演、信息整理、方案生成等二次工作；人类负责价值判断、审美判断、最终拍板。',
  },
  {
    name: '熵减命令',
    symbol: '↘',
    content: '系统的唯一目的是高熵（混乱/未知）转化为低熵（结构/已知）。',
  },
  {
    name: '多元世界观',
    symbol: '∥',
    content: '蓝图层 = 应然（流动的意识）；现实层 = 实然（流动的物质）；偏差驱动行动。',
  },
  {
    name: '量变质变',
    symbol: '∞',
    content: '记录积累到一定量时，分析研究过程，为人机交互的安全与预警提供判断依据。',
  },
  {
    name: '做减法',
    symbol: '−',
    content: '如无必要，勿增实体。最简路径即最优路径。',
  },
];
---
<Base title="指南针 — Walker">
  <div class="max-w-4xl mx-auto px-6 pt-28 pb-20">
    <!-- 页头 -->
    <div class="text-center mb-20">
      <h1 class="font-heading text-3xl text-parchment mb-4 tracking-wide">指南针</h1>
      <p class="text-mist-light text-base">
        {totalPosts} 篇日志，{totalTags} 个方向
      </p>
    </div>

    <!-- 五层逻辑 -->
    <section class="mb-24">
      <div class="flex items-center gap-4 mb-10">
        <h2 class="font-heading text-xs tracking-[0.3em] uppercase text-gold/50">操作系统</h2>
        <div class="flex-1 h-px bg-gradient-to-r from-gold/15 to-transparent"></div>
      </div>

      <div class="space-y-6">
        {axioms.map(axiom => (
          <div class="group flex gap-5 items-start p-4 rounded-xl transition-colors hover:bg-sea-mid/30">
            <div class="shrink-0 w-10 h-10 rounded-lg bg-gold/10 border border-gold/15 flex items-center justify-center font-heading text-gold/70 text-lg">
              {axiom.symbol}
            </div>
            <div>
              <h3 class="font-heading text-parchment text-base mb-1 group-hover:text-gold transition-colors">
                {axiom.name}
              </h3>
              <p class="text-parchment/50 text-sm leading-relaxed">
                {axiom.content}
              </p>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- 标签图谱 -->
    <section>
      <div class="flex items-center gap-4 mb-10">
        <h2 class="font-heading text-xs tracking-[0.3em] uppercase text-gold/50">兴趣星图</h2>
        <div class="flex-1 h-px bg-gradient-to-r from-gold/15 to-transparent"></div>
      </div>

      <p class="text-parchment/40 text-sm mb-8 text-center max-w-md mx-auto leading-relaxed">
        不定义自己是什么，而是展示自己关注什么。点击任一方向，探索那片海域。
      </p>

      <TagMap tags={tags} />
    </section>
  </div>
  <script src="../scripts/scroll-fade.ts"></script>
</Base>
