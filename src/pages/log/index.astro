---
import Base from '../../layouts/Base.astro';
import TraceCard from '../../components/TraceCard.astro';
import { getCollection } from 'astro:content';
import { DOMAIN_LABELS } from '../../utils/domains';
import { FORMAT_LABELS } from '../../utils/formats';

const allLogs = (await getCollection('log', ({ data }) => data.published))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

// 收集所有可用筛选项
const allDomains = [...new Set(allLogs.map(e => e.data.domain))];
const allTypes = [...new Set(allLogs.map(e => e.data.type))];
const tagCountMap = new Map<string, number>();
allLogs.forEach(entry => {
  entry.data.tags.forEach(tag => {
    tagCountMap.set(tag, (tagCountMap.get(tag) ?? 0) + 1);
  });
});
const allTags = [...tagCountMap.entries()]
  .sort((a, b) => b[1] - a[1])
  .map(([tag]) => tag);
---

<Base title="航海日志 — Walker" theme="nature">

  <div class="max-w-5xl mx-auto px-6 pt-28 pb-20">
    <!-- 页面标题 -->
    <div class="mb-10">
      <div class="flex items-center gap-2 mb-1">
        <span class="w-1.5 h-1.5 rounded-full bg-bio-cyan/60"></span>
        <span class="text-xs font-mono text-parchment/25 uppercase tracking-wider">Log</span>
      </div>
      <h1 class="font-heading text-4xl md:text-5xl text-parchment tracking-wide">航海日志</h1>
      <p class="mt-3 text-parchment/30 text-sm font-body">
        <span id="log-count">{allLogs.length}</span> 条记录
      </p>
      <div class="mt-4 h-px bg-gradient-to-r from-white/[0.08] to-transparent"></div>
    </div>

    <!-- 三维筛选器（客户端） -->
    <div class="mb-10 space-y-3" id="log-filters">
      <!-- 海域 -->
      <div class="flex flex-wrap items-center gap-2">
        <span class="text-parchment-dim text-xs font-mono tracking-wider w-12 shrink-0">海域</span>
        <button class="filter-btn active" data-filter="domain" data-value="">全部</button>
        {allDomains.map(d => (
          <button class="filter-btn" data-filter="domain" data-value={d}>
            {DOMAIN_LABELS[d] ?? d}
          </button>
        ))}
      </div>
      <!-- 形态 -->
      <div class="flex flex-wrap items-center gap-2">
        <span class="text-parchment-dim text-xs font-mono tracking-wider w-12 shrink-0">形态</span>
        <button class="filter-btn active" data-filter="type" data-value="">全部</button>
        {allTypes.map(t => (
          <button class="filter-btn" data-filter="type" data-value={t}>
            {FORMAT_LABELS[t] ?? t}
          </button>
        ))}
      </div>
      <!-- 主题 -->
      <div class="flex flex-wrap items-center gap-2">
        <span class="text-parchment-dim text-xs font-mono tracking-wider w-12 shrink-0">主题</span>
        <button class="filter-btn active" data-filter="tag" data-value="">全部</button>
        {allTags.slice(0, 15).map(tag => (
          <button class="filter-btn" data-filter="tag" data-value={tag}>
            {tag}
            <span class="opacity-60 text-[10px] ml-1">{tagCountMap.get(tag)}</span>
          </button>
        ))}
      </div>
    </div>

    <!-- 日志列表 -->
    <div id="log-list" class="columns-1 md:columns-2 lg:columns-3 gap-6">
      {allLogs.map(entry => (
        <div
          class="log-item"
          data-domain={entry.data.domain}
          data-type={entry.data.type}
          data-tags={entry.data.tags.join(',')}
        >
          <TraceCard
            title={entry.data.title}
            date={entry.data.date}
            tags={entry.data.tags}
            type={entry.data.type}
            domain={entry.data.domain}
            slug={entry.id}
            cover={entry.data.cover}
            excerpt={entry.body ? entry.body.replace(/^import\s+.*$/gm, '').replace(/<[^>]+>/g, '').replace(/[#*_`\[\]()>|]/g, '').trim().slice(0, 150) + '...' : undefined}
          />
        </div>
      ))}
    </div>

    <!-- 空状态 -->
    <p id="log-empty" class="text-parchment/30 text-center py-20 hidden">
      这片海域暂时没有记录。
    </p>
  </div>

  <script>
    const filters: Record<string, string> = { domain: '', type: '', tag: '' };
    const items = document.querySelectorAll<HTMLElement>('.log-item');
    const countEl = document.getElementById('log-count');
    const emptyEl = document.getElementById('log-empty');
    const listEl = document.getElementById('log-list');

    // 从 URL 参数初始化筛选状态
    const params = new URLSearchParams(window.location.search);
    ['domain', 'type', 'tag'].forEach(key => {
      const val = params.get(key);
      if (val) filters[key] = val;
    });

    function applyFilters() {
      let visible = 0;
      items.forEach(item => {
        const domain = item.dataset.domain ?? '';
        const type = item.dataset.type ?? '';
        const tags = (item.dataset.tags ?? '').split(',');

        const matchDomain = !filters.domain || domain === filters.domain;
        const matchType = !filters.type || type === filters.type;
        const matchTag = !filters.tag || tags.includes(filters.tag);

        if (matchDomain && matchType && matchTag) {
          item.style.display = '';
          visible++;
        } else {
          item.style.display = 'none';
        }
      });

      if (countEl) countEl.textContent = String(visible);
      if (emptyEl) emptyEl.classList.toggle('hidden', visible > 0);
      if (listEl) listEl.classList.toggle('hidden', visible === 0);

      // 更新 URL（不刷新）
      const url = new URL(window.location.href);
      ['domain', 'type', 'tag'].forEach(key => {
        if (filters[key]) url.searchParams.set(key, filters[key]);
        else url.searchParams.delete(key);
      });
      history.replaceState(null, '', url.toString());
    }

    function updateButtonStates() {
      document.querySelectorAll<HTMLElement>('#log-filters .filter-btn').forEach(btn => {
        const filterKey = btn.dataset.filter ?? '';
        const filterVal = btn.dataset.value ?? '';
        btn.classList.toggle('active', filters[filterKey] === filterVal);
      });
    }

    // 绑定事件
    document.querySelectorAll<HTMLElement>('#log-filters .filter-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const key = btn.dataset.filter ?? '';
        const val = btn.dataset.value ?? '';
        filters[key] = val;
        updateButtonStates();
        applyFilters();
      });
    });

    // 初始化
    updateButtonStates();
    applyFilters();
  </script>

</Base>
