---
import Base from '../layouts/Base.astro';
import SocialLinks from '../components/SocialLinks.astro';
import ContactSection from '../components/ContactSection.astro';
---

<Base title="关于 — Walker" description="Walker 的个人空间。写代码、做饭、拍照、思考哲学、在路上。">
  <div class="max-w-3xl mx-auto px-6 pt-28 pb-20">

    <!-- 页面标题 -->
    <div class="mb-16">
      <div class="flex items-center gap-3 mb-1">
        <span class="w-1.5 h-1.5 rounded-full bg-gold/60"></span>
        <span class="text-xs font-mono text-parchment/25 uppercase tracking-wider">About</span>
      </div>
      <h1 class="font-heading text-4xl md:text-5xl text-parchment tracking-wide">关于</h1>
      <div class="mt-4 h-px bg-gradient-to-r from-white/[0.08] to-transparent"></div>
    </div>

    <!-- 个人简介 -->
    <section class="mb-16">
      <div class="panel-glass p-8">
        <div class="flex items-start gap-6">
          <div class="shrink-0 w-16 h-16 rounded-full bg-gradient-to-br from-bio-cyan/20 to-gold/20 border-2 border-white/[0.08] flex items-center justify-center">
            <iconify-icon icon="lucide:anchor" width="24" height="24" class="text-parchment/50"></iconify-icon>
          </div>
          <div>
            <h2 class="font-heading text-xl text-parchment mb-2">Walker</h2>
            <p class="text-parchment/60 text-sm leading-relaxed">
              写代码、做饭、拍照、思考哲学、在路上。用 AI 探索效率和创造力的交叉点，
              相信「人类主权」原则 — AI 负责推演，人类负责判断。
            </p>
            <p class="text-parchment/40 text-sm leading-relaxed mt-3">
              这个站点是我的个人知识空间，记录航海途中的思考、工具和发现。
              所有内容在 Obsidian 中写作，通过 Git 推送到 GitHub，由 Vercel 自动部署。
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- 技能和兴趣 -->
    <section class="mb-16">
      <div class="flex items-center gap-4 mb-8">
        <h2 class="text-parchment/25 text-xs font-mono uppercase tracking-wider">技能和兴趣</h2>
        <div class="flex-1 h-px bg-gradient-to-r from-white/[0.08] to-transparent"></div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div class="panel-glass p-5 group">
          <div class="flex items-center gap-3 mb-3">
            <div class="w-9 h-9 rounded-lg bg-bio-cyan/10 flex items-center justify-center">
              <iconify-icon icon="lucide:code-2" width="16" height="16" class="text-bio-cyan/70"></iconify-icon>
            </div>
            <h3 class="font-heading text-parchment/80 text-sm">AI 工程</h3>
          </div>
          <p class="text-parchment/40 text-xs leading-relaxed">
            Prompt Engineering / AI Agent 构建 / LLM 应用开发 / 人机协作工作流
          </p>
        </div>

        <div class="panel-glass p-5 group">
          <div class="flex items-center gap-3 mb-3">
            <div class="w-9 h-9 rounded-lg bg-gold/10 flex items-center justify-center">
              <iconify-icon icon="lucide:pen-tool" width="16" height="16" class="text-gold/70"></iconify-icon>
            </div>
            <h3 class="font-heading text-parchment/80 text-sm">内容创作</h3>
          </div>
          <p class="text-parchment/40 text-xs leading-relaxed">
            技术写作 / 知识整理 / 跨平台内容 / 从灵感到输出的完整链路
          </p>
        </div>

        <div class="panel-glass p-5 group">
          <div class="flex items-center gap-3 mb-3">
            <div class="w-9 h-9 rounded-lg bg-coral/10 flex items-center justify-center">
              <iconify-icon icon="lucide:terminal" width="16" height="16" class="text-coral/70"></iconify-icon>
            </div>
            <h3 class="font-heading text-parchment/80 text-sm">全栈开发</h3>
          </div>
          <p class="text-parchment/40 text-xs leading-relaxed">
            TypeScript / Astro / React / Node.js / 静态站点 / 自动化部署
          </p>
        </div>

        <div class="panel-glass p-5 group">
          <div class="flex items-center gap-3 mb-3">
            <div class="w-9 h-9 rounded-lg bg-emerald/10 flex items-center justify-center">
              <iconify-icon icon="lucide:camera" width="16" height="16" class="text-emerald/70"></iconify-icon>
            </div>
            <h3 class="font-heading text-parchment/80 text-sm">生活探索</h3>
          </div>
          <p class="text-parchment/40 text-xs leading-relaxed">
            摄影 / 烹饪 / 哲学阅读 / 旅行记录 / 观察与反思
          </p>
        </div>
      </div>
    </section>

    <!-- 项目亮点 -->
    <section class="mb-16">
      <div class="flex items-center gap-4 mb-8">
        <h2 class="text-parchment/25 text-xs font-mono uppercase tracking-wider">项目</h2>
        <div class="flex-1 h-px bg-gradient-to-r from-white/[0.08] to-transparent"></div>
      </div>

      <div class="space-y-3">
        <a href="/works" class="panel-glass p-5 flex items-center gap-4 group no-underline block">
          <div class="w-10 h-10 rounded-xl bg-bio-cyan/10 border border-bio-cyan/20 flex items-center justify-center shrink-0">
            <iconify-icon icon="lucide:ship" width="18" height="18" class="text-bio-cyan/70"></iconify-icon>
          </div>
          <div class="flex-1 min-w-0">
            <h3 class="text-parchment/80 text-sm font-heading group-hover:text-bio-cyan transition-colors">Walker 知识空间</h3>
            <p class="text-parchment/35 text-xs mt-0.5">Astro 6 + Tailwind v4 构建的个人博客和知识管理系统</p>
          </div>
          <iconify-icon icon="lucide:arrow-right" width="14" height="14" class="text-parchment/20 group-hover:text-bio-cyan transition-colors shrink-0"></iconify-icon>
        </a>
      </div>
    </section>
  </div>

  <!-- 社交链接 -->
  <SocialLinks />

  <!-- 联系方式 -->
  <ContactSection />
</Base>
