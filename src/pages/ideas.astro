---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';
import IdeaCard from '../components/IdeaCard.astro';

const allIdeas = (await getCollection('idea', ({ data }) => data.published))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const allTags = [...new Set(allIdeas.flatMap(e => e.data.tags))].sort();
---

<Base title="Ideas — Walker">
  <div class="max-w-4xl mx-auto px-6 pt-28 pb-20">
    <div class="mb-10">
      <div class="flex items-center gap-3 mb-1">
        <span class="w-1.5 h-1.5 rounded-full bg-gold/60"></span>
        <span class="text-xs font-mono text-parchment/25 uppercase tracking-wider">Ideas</span>
      </div>
      <h1 class="font-heading text-4xl md:text-5xl text-parchment tracking-wide">Ideas</h1>
      <p class="text-parchment/40 text-sm font-body mt-3">
        Walker 发布自己没空实现的想法。如果你感兴趣，<a href="/about" class="text-bio-cyan/60 hover:text-bio-cyan no-underline">联系我</a>。
      </p>
      <div class="mt-4 h-px bg-gradient-to-r from-white/[0.08] to-transparent"></div>
    </div>

    <!-- 标签筛选 -->
    <div class="mb-8 flex flex-wrap gap-2" id="idea-filters">
      <button class="filter-btn active" data-value="">全部</button>
      {allTags.map(tag => (
        <button class="filter-btn" data-value={tag}>{tag}</button>
      ))}
    </div>

    {allIdeas.length === 0 ? (
      <p class="text-parchment/30 text-center py-20">暂时没有想法。</p>
    ) : (
      <div class="grid gap-6 md:grid-cols-2" id="idea-list">
        {allIdeas.map(idea => (
          <div class="idea-item" data-tags={idea.data.tags.join(',')}>
            <IdeaCard
              title={idea.data.title}
              scenario={idea.data.scenario}
              tags={idea.data.tags}
              followups={idea.data.followups}
              slug={idea.id}
            />
          </div>
        ))}
      </div>
    )}

    <p id="idea-empty" class="text-parchment/30 text-center py-20 hidden">
      这个标签暂时没有想法。
    </p>
  </div>

  <script>
    let activeTag = '';
    const items = document.querySelectorAll<HTMLElement>('.idea-item');
    const emptyEl = document.getElementById('idea-empty');
    const listEl = document.getElementById('idea-list');

    function applyFilter() {
      let visible = 0;
      items.forEach(item => {
        const tags = (item.dataset.tags ?? '').split(',');
        if (!activeTag || tags.includes(activeTag)) {
          item.style.display = '';
          visible++;
        } else {
          item.style.display = 'none';
        }
      });
      if (emptyEl) emptyEl.classList.toggle('hidden', visible > 0);
      if (listEl) listEl.classList.toggle('hidden', visible === 0);
    }

    document.querySelectorAll<HTMLElement>('#idea-filters .filter-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        activeTag = btn.dataset.value ?? '';
        document.querySelectorAll('#idea-filters .filter-btn').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        applyFilter();
      });
    });
  </script>
</Base>
