---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';
import WorkCard from '../components/WorkCard.astro';
import { PLATFORM_LABELS } from '../utils/platforms';

const allWorks = (await getCollection('work', ({ data }) => data.published))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const platforms = [...new Set(allWorks.map(e => e.data.platform))];
---

<Base title="作品 — Walker" theme="charcoal">
  <div class="max-w-5xl mx-auto px-6 pt-28 pb-20">
    <div class="mb-10">
      <div class="flex items-center gap-3 mb-1">
        <span class="w-1.5 h-1.5 rounded-full bg-emerald/60"></span>
        <span class="text-xs font-mono text-parchment/25 uppercase tracking-wider">Works</span>
      </div>
      <h1 class="font-heading text-4xl md:text-5xl text-parchment tracking-wide">作品</h1>
      <p class="text-parchment/40 text-sm font-body mt-3">
        Walker 在其他平台发布的内容。
      </p>
      <div class="mt-4 h-px bg-gradient-to-r from-white/[0.08] to-transparent"></div>
    </div>

    <!-- 平台筛选 -->
    <div class="mb-8 flex flex-wrap gap-2" id="works-filters">
      <button class="filter-btn active" data-value="">全部</button>
      {platforms.map(p => (
        <button class="filter-btn" data-value={p}>{PLATFORM_LABELS[p] ?? p}</button>
      ))}
    </div>

    {allWorks.length === 0 ? (
      <p class="text-parchment/30 text-center py-20">暂时没有作品。</p>
    ) : (
      <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3" id="works-list">
        {allWorks.map(work => (
          <div class="work-item" data-platform={work.data.platform}>
            <WorkCard
              title={work.data.title}
              platform={work.data.platform}
              url={work.data.url}
              cover={work.data.cover}
              description={work.data.description}
              tags={work.data.tags}
            />
          </div>
        ))}
      </div>
    )}

    <p id="works-empty" class="text-parchment/30 text-center py-20 hidden">
      这个平台暂时没有作品。
    </p>
  </div>

  <script>
    let activePlatform = '';
    const items = document.querySelectorAll<HTMLElement>('.work-item');
    const emptyEl = document.getElementById('works-empty');
    const listEl = document.getElementById('works-list');

    function applyFilter() {
      let visible = 0;
      items.forEach(item => {
        const platform = item.dataset.platform ?? '';
        if (!activePlatform || platform === activePlatform) {
          item.style.display = '';
          visible++;
        } else {
          item.style.display = 'none';
        }
      });
      if (emptyEl) emptyEl.classList.toggle('hidden', visible > 0);
      if (listEl) listEl.classList.toggle('hidden', visible === 0);
    }

    document.querySelectorAll<HTMLElement>('#works-filters .filter-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        activePlatform = btn.dataset.value ?? '';
        document.querySelectorAll('#works-filters .filter-btn').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        applyFilter();
      });
    });
  </script>
</Base>
